# CiteWise 配置
# 复制此文件为 .env 并填入真实值

# 智谱 GLM API（必填）
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL=glm-4.7

# 安全配置（必填 — 生产环境必须修改）
JWT_SECRET=change-me-to-a-random-secret-in-production

# Embedding 配置
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSION=2048

# 服务器配置
HOST=127.0.0.1
PORT=8080
RELOAD=true
