{
  "builds": [{ "src": "static/**", "use": "@vercel/static" }],
  "routes": [
    { "src": "/vendor/(.*)", "dest": "/static/vendor/$1" },
    { "src": "/js/(.*)", "dest": "/static/js/$1" },
    { "src": "/css/(.*)", "dest": "/static/css/$1" },
    { "src": "/html/(.*)", "dest": "/static/html/$1" },
    { "src": "/(.*\\.(html|ico|png|jpg|svg))", "dest": "/static/$1" },
    { "src": "/", "dest": "/static/index.html" }
  ]
}
